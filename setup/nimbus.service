[Unit]
Description=Nimbus Personal App Store
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
WorkingDirectory=/opt/nimbus/backend
EnvironmentFile=-/etc/default/nimbus
ExecStart=/bin/sh -c 'exec /opt/nimbus-venv/bin/uvicorn main:app --host "${NIMBUS_BIND_HOST:-127.0.0.1}" --port "${NIMBUS_PORT:-8000}"'
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nimbus

[Install]
WantedBy=multi-user.target
