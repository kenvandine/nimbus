#!/bin/sh
set -eu

typelib_path=
for candidate in "$SNAP"/usr/lib/*/girepository-1.0; do
  if [ -d "$candidate" ]; then
    typelib_path="$candidate"
    break
  fi
done

export PYTHONDONTWRITEBYTECODE=1
export PYTHONPATH="${SNAP}/backend:${SNAP}/usr/lib/python3/dist-packages${PYTHONPATH:+:$PYTHONPATH}"
if [ -n "$typelib_path" ]; then
  export GI_TYPELIB_PATH="$typelib_path${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"
fi
export GIT_EXEC_PATH="${SNAP}/usr/lib/git-core"
export GIT_TEMPLATE_DIR="${SNAP}/usr/share/git-core/templates"
export PATH="${SNAP}/usr/lib/git-core:${SNAP}/usr/bin:${SNAP}/bin${PATH:+:$PATH}"

# Pull model-provider / openai-url from snap config when present; otherwise
# inherit defaults from snapcraft.yaml + per-provider defaults in config.py.
# Validation lives in snap/hooks/configure so bad values are rejected at
# `snap set` time.
if command -v snapctl >/dev/null 2>&1; then
  provider="$(snapctl get model-provider 2>/dev/null || true)"
  if [ -n "$provider" ]; then
    export NIMBUS_MODEL_PROVIDER="$provider"
  fi
  openai_url="$(snapctl get openai-url 2>/dev/null || true)"
  if [ -n "$openai_url" ]; then
    export NIMBUS_OPENAI_URL="$openai_url"
  fi
  appstore_visible="$(snapctl get appstore-visible 2>/dev/null || true)"
  if [ "$appstore_visible" = "true" ]; then
    export NIMBUS_APPSTORE_VISIBLE=true
  else
    export NIMBUS_APPSTORE_VISIBLE=false
  fi
  preseed_apps="$(snapctl get preseed-apps 2>/dev/null || true)"
  if [ -n "$preseed_apps" ]; then
    export NIMBUS_PRESEED_APPS="$preseed_apps"
  fi
  appstore_whitelist="$(snapctl get appstore-whitelist 2>/dev/null || true)"
  if [ -n "$appstore_whitelist" ]; then
    export NIMBUS_APPSTORE_WHITELIST="$appstore_whitelist"
  fi
fi

# Marker the configure hook checks before issuing a snapctl restart, so we
# avoid restarts during the first-install boot when the daemon isn't up yet.
if [ -n "${SNAP_DATA:-}" ]; then
  mkdir -p "$SNAP_DATA" 2>/dev/null || true
  : > "$SNAP_DATA/.daemon-started" 2>/dev/null || true
fi

exec "${SNAP}/bin/python3" -m uvicorn main:app \
  --app-dir "${SNAP}/backend" \
  --host "${NIMBUS_BIND_HOST:-0.0.0.0}" \
  --port "${NIMBUS_PORT:-8000}"
